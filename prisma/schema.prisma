generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id        String   @id @default(cuid())
  userId    String?
  total     Int
  status    String   @default("pending")
  cardText  String?
  createdAt DateTime @default(now())

  items OrderItem[]
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  bouquetId String
  quantity  Int
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
